      "bo_league_champions_kayn": {
        "name": "Kayn (Shadow Reaper)",
        "attack": "Shadow Reaper - Darkin Scythe: Kayn sweeps with his scythe, dealing <#ff9028ff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>105% attack damage<> as physical damage. While Darkin Ascension is active, the strike hits harder and heals Kayn.",
        "skill": "Q - Reaping Slash: Kayn dashes a short distance and slashes in front of him, dealing <#ff9028ff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>85% attack damage<> physical damage. Darkin Ascension empowers the slash.",
        "skill2": "W - Blade's Reach: Kayn carves a long line with his scythe, dealing <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> physical damage and <#ffb900ff>slowing enemies for 1.0s<>. In Darkin Ascension it is wider and briefly knocks enemies airborne.",
        "ult": "R - Umbral Trespass: Kayn enters an enemy champion, becoming untargetable for a short moment, then bursts out to deal <#ff9028ff>180<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>160% attack damage<> physical damage and gains Darkin Ascension for <#ffb900ff>10.0s<>."
      },
      "test_mod_kayn": {
        "name": "Kayn (Shadow Reaper)",
        "attack": "Shadow Reaper - Darkin Scythe: Kayn sweeps with his scythe, dealing <#ff9028ff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>105% attack damage<> as physical damage. While Darkin Ascension is active, the strike hits harder and heals Kayn.",
        "skill": "Q - Reaping Slash: Kayn dashes a short distance and slashes in front of him, dealing <#ff9028ff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>85% attack damage<> physical damage. Darkin Ascension empowers the slash.",
        "skill2": "W - Blade's Reach: Kayn carves a long line with his scythe, dealing <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> physical damage and <#ffb900ff>slowing enemies for 1.0s<>. In Darkin Ascension it is wider and briefly knocks enemies airborne.",
        "ult": "R - Umbral Trespass: Kayn enters an enemy champion, becoming untargetable for a short moment, then bursts out to deal <#ff9028ff>180<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>160% attack damage<> physical damage and gains Darkin Ascension for <#ffb900ff>10.0s<>."
      },
      "bo_league_champions_yasuo": {
        "name": "Yasuo (Unforgiven)",
        "attack": "Way of the Wanderer: Yasuo slashes with his katana, dealing <#ff9028ff>8<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> physical damage. Every third basic attack grants a short Flow shield.",
        "skill": "Q - Steel Tempest: each cast thrusts a wind blade forward, dealing <#ff9028ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% attack damage<>. The second Q is stronger. The third Q fires a tornado that knocks enemies airborne and readies Last Breath.",
        "skill2": "W/E - Sweeping Blade + Wind Wall: Yasuo dashes through the chosen direction, slicing enemies for <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>55% attack damage<>, gaining a small shield, then raises a wind wall that blocks movement skills and pushes enemies back.",
        "ult": "R - Last Breath: Yasuo blinks behind an enemy champion and strikes for <#ff9028ff>110<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>120% attack damage<>. If Steel Tempest tornado recently hit, Last Breath becomes empowered, dealing higher damage in an area and knocking enemies airborne."
      },
      "test_mod_yasuo": {
        "name": "Yasuo (Unforgiven)",
        "attack": "Way of the Wanderer: Yasuo slashes with his katana, dealing <#ff9028ff>8<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> physical damage. Every third basic attack grants a short Flow shield.",
        "skill": "Q - Steel Tempest: each cast thrusts a wind blade forward, dealing <#ff9028ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% attack damage<>. The second Q is stronger. The third Q fires a tornado that knocks enemies airborne and readies Last Breath.",
        "skill2": "W/E - Sweeping Blade + Wind Wall: Yasuo dashes through the chosen direction, slicing enemies for <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>55% attack damage<>, gaining a small shield, then raises a wind wall that blocks movement skills and pushes enemies back.",
        "ult": "R - Last Breath: Yasuo blinks behind an enemy champion and strikes for <#ff9028ff>110<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>120% attack damage<>. If Steel Tempest tornado recently hit, Last Breath becomes empowered, dealing higher damage in an area and knocking enemies airborne."
      },
      "bo_league_champions_jinx": {
        "name": "Jinx (Loose Cannon)",
        "attack": "Pow-Pow / Fishbones: basic attacks default to Pow-Pow and build minigun attack speed. During the short Fishbones window, attacks become splash rockets and clear Pow-Pow stacks.",
        "skill": "Switcheroo!: when an enemy target is available, Jinx briefly swaps to Fishbones for splash rocket attacks, then automatically returns to Pow-Pow.",
        "skill2": "Zap! + Flame Chompers!: fires a long electric shot that damages and slows, then throws Flame Chompers ahead to bite, stun, and burn enemies caught in the line.",
        "ult": "Super Mega Death Rocket!: fires a huge shark rocket across the map. On champion hit it explodes, deals heavy physical damage, and triggers Get Excited movement and attack speed."
      },
      "test_mod_jinx": {
        "name": "Jinx (Loose Cannon)",
        "attack": "Pow-Pow / Fishbones: basic attacks default to Pow-Pow and build minigun attack speed. During the short Fishbones window, attacks become splash rockets and clear Pow-Pow stacks.",
        "skill": "Switcheroo!: when an enemy target is available, Jinx briefly swaps to Fishbones for splash rocket attacks, then automatically returns to Pow-Pow.",
        "skill2": "Zap! + Flame Chompers!: fires a long electric shot that damages and slows, then throws Flame Chompers ahead to bite, stun, and burn enemies caught in the line.",
        "ult": "Super Mega Death Rocket!: fires a huge shark rocket across the map. On champion hit it explodes, deals heavy physical damage, and triggers Get Excited movement and attack speed."
      },
      "bo_league_champions_thresh": {
        "name": "Thresh (Chain Warden)",
        "attack": "Damnation / Flay chain: Thresh lashes with his chain scythe for <#ff9028ff>physical damage<> and a small <#a974ffff>magic burn<>. Every third basic attack becomes an empowered soul lash that slows the target and resets the chain-charge cycle.",
        "skill": "Q - Death Sentence: Thresh throws a non-piercing hook chain in a long line. The first enemy hit takes <#a974ffff>65<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> magic damage, is stunned, heavily slowed, and has movement skills briefly blocked. Champion hits grant a permanent Damnation soul stack.",
        "skill2": "W/E - Dark Passage / Flay: Thresh lights his lantern to shield himself, then sweeps the chain scythe forward. Enemies hit take magic damage, are pushed back, slowed, and grant a Damnation soul stack on champion hit.",
        "ult": "R - The Box: Thresh summons spectral prison walls around himself. Enemies inside take heavy magic damage, are strongly slowed, and have movement skills briefly blocked. The Box lingers as a slowing field, and champion hits grant permanent souls."
      },
      "test_mod_thresh": {
        "name": "Thresh (Chain Warden)",
        "attack": "Damnation / Flay chain: Thresh lashes with his chain scythe for <#ff9028ff>physical damage<> and a small <#a974ffff>magic burn<>. Every third basic attack becomes an empowered soul lash that slows the target and resets the chain-charge cycle.",
        "skill": "Q - Death Sentence: Thresh throws a non-piercing hook chain in a long line. The first enemy hit takes <#a974ffff>65<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> magic damage, is stunned, heavily slowed, and has movement skills briefly blocked. Champion hits grant a permanent Damnation soul stack.",
        "skill2": "W/E - Dark Passage / Flay: Thresh lights his lantern to shield himself, then sweeps the chain scythe forward. Enemies hit take magic damage, are pushed back, slowed, and grant a Damnation soul stack on champion hit.",
        "ult": "R - The Box: Thresh summons spectral prison walls around himself. Enemies inside take heavy magic damage, are strongly slowed, and have movement skills briefly blocked. The Box lingers as a slowing field, and champion hits grant permanent souls."
      },
      "bo_league_champions_darius": {
        "name": "Darius",
        "attack": "Hemorrhage: Darius, the Hand of Noxus, cleaves with his axe for <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as physical damage and advances Hemorrhage. At five stacks he gains Noxian Might. If Crippling Strike is primed, the next attack deals heavier damage and <#ef5350ff>slows<> the target.",
        "skill": "Q - Decimate: Darius spins his axe in a red outer circle, dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> as physical damage, applying Hemorrhage, and healing himself when enemies are struck. During Noxian Might, Decimate deals more damage and heals more.",
        "skill2": "E/W - Apprehend and Crippling Strike: Darius sweeps his axe forward in a chain-like hook line, dealing <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>60% attack damage<>, briefly stunning, slowing, and blocking movement skills. The cast primes his next attack as Crippling Strike.",
        "ult": "R - Noxian Guillotine: Darius rushes behind an enemy champion and executes with true damage. The blow scales with Hemorrhage stacks, reaches its highest damage at five stacks or during Noxian Might, and plays Darius's Noxian Guillotine voice line."
      },
      "test_mod_darius": {
        "name": "Darius",
        "attack": "Hemorrhage: Darius, the Hand of Noxus, cleaves with his axe for <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as physical damage and advances Hemorrhage. At five stacks he gains Noxian Might. If Crippling Strike is primed, the next attack deals heavier damage and <#ef5350ff>slows<> the target.",
        "skill": "Q - Decimate: Darius spins his axe in a red outer circle, dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> as physical damage, applying Hemorrhage, and healing himself when enemies are struck. During Noxian Might, Decimate deals more damage and heals more.",
        "skill2": "E/W - Apprehend and Crippling Strike: Darius sweeps his axe forward in a chain-like hook line, dealing <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>60% attack damage<>, briefly stunning, slowing, and blocking movement skills. The cast primes his next attack as Crippling Strike.",
        "ult": "R - Noxian Guillotine: Darius rushes behind an enemy champion and executes with true damage. The blow scales with Hemorrhage stacks, reaches its highest damage at five stacks or during Noxian Might, and plays Darius's Noxian Guillotine voice line."
      }
    }
  },
  "zh-hans": {
    "description": {
      "bo_league_champions_aatrox": {
        "name": "亚托克斯",
        "attack": "暗裔剑魔亚托克斯的赐死剑气：强化下一次巨剑攻击，造成<#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力112%<>的<#ff9028ff>物理伤害<>。",
        "skill": "Q - 暗裔利刃：每次施放只挥出一段剑招：第一段窄幅前刺，第二段横向宽扫，第三段重砸伤害更高并将敌人击飞<#ef5350ff>0.5秒<>。再次施放Q才会进入下一段，不会一次打出三段。",
        "skill2": "W - 恶火束链：亚托克斯向前发射恶火锁链，命中敌方英雄时造成伤害并<#ffb900ff>减速<>。短暂延迟后锁链收束，再次造成伤害并短暂束缚路径上的敌人。",
        "ult": "R - 大灭：亚托克斯释放恶魔形态，持续<#ffb900ff>10.0秒<>，获得<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75攻击力<>、<i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20%移动速度<>和<#6aff55ff>50%吸血<>。施放时短暂恐惧附近敌人。"
      },
      "bo_league_champions_viktor": {
        "name": "维克托",
        "attack": "奥术先驱 / 机械先驱维克托：奥术脉冲造成<#a974ffff>12<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75%法术强度<>的魔法伤害。虹吸蓄能时下一次普攻造成<#a974ffff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>115%法术强度<>并获得护盾。光荣进化会强化后续技能。",
        "skill": "E - 海克斯射线：维克托的第三机械臂向指定方向发射激光，对直线敌人造成魔法伤害。进化后留下余震，造成伤害并短暂减速。命中敌方英雄会推进光荣进化。",
        "skill2": "Q/W - 虹吸能量 + 重力场：维克托获得护盾并强化下一次普攻，随后在目标位置制造重力场。区域内敌人被减速，停留到坍缩时会被眩晕；进化后还会干扰位移技能。",
        "ult": "R - 奥术风暴：维克托在目标位置召唤奥术风暴，造成初始爆发魔法伤害并干扰敌方技能，随后持续脉冲。施放奥术风暴会推进光荣进化；完全进化后范围更大、持续更久、脉冲更快。"
      },
      "bo_league_champions_veigar": {
        "name": "维迦",
        "attack": "向目标发射一枚魔法弹，造成<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的100%<>的<#ff9028ff>物理伤害<>。",
        "skill": "短暂延迟后召唤暗物质从天而降，对<#ffb900ff>35范围<>内的敌人造成<#a974ffff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的180%<>的<#a974ffff>魔法伤害<>。命中敌方英雄可获得<i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>22点法术强度，直到死亡<>；小兵受到的伤害减半。",
        "skill2": "扭曲空间边缘，创造视界牢笼。<#ffb900ff>1.0秒<>后，牢笼内的敌方英雄被<#ef5350ff>晕眩1.5秒<>，随后牢笼消失。",
        "ult": "向一名敌方英雄释放一团暗黑魔法，造成<#a974ffff>150<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的200%<>的<#a974ffff>魔法伤害<>。"
      },
      "bo_league_champions_jhin": {
        "name": "烬",
        "attack": "向目标射出一发子弹，造成<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的100%<>的<#ff9028ff>物理伤害<>。每第四次攻击会使用红色子弹，造成<#ff9028ff>100<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的200%<>的伤害。射出第四发后，烬会装填弹药，在下一次攻击前攻击速度大幅降低。",
        "skill": "曼舞手雷：向范围内的一名敌人投掷一枚会弹跳的手雷。手雷可跳向附近另一名敌人，命中时造成<#ff9028ff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的75%<>的<#ff9028ff>物理伤害<>。",
        "skill2": "致命华彩：进行一次远程直线射击，对敌方英雄造成<#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的70%<>的<#ff9028ff>物理伤害<>，对小兵造成<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的30%<>的伤害。被命中的敌方英雄被<#ef5350ff>晕眩0.5秒<>。",
        "ult": "完美谢幕：烬架好武器，将自己固定在原地，向指定方向射出四发只对英雄生效的子弹。每发子弹在命中第一个敌方英雄时停下。前三发各造成<#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的150%<>的<#ff9028ff>物理伤害<>；威力更强的红色第四发子弹造成<#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的300%<>的伤害。"
      },
      "bo_league_champions_vayne": {
        "name": "薇恩",
        "attack": "向目标射出一支弩箭，造成<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的100%<>的<#ff9028ff>物理伤害<>。每第三次普通攻击会触发圣银弩箭，造成<#f5f5f5ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的35%<> + <#f5f5f5ff>目标最大生命值的4%<>的<#f5f5f5ff>固定伤害<>。",
        "skill": "闪避突袭：向指定方向滚动一小段距离，并强化下一次普通攻击，使其造成<#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的150%<>的伤害。在终极时刻期间，闪避突袭移动距离更远，并使薇恩<#ffb900ff>隐身1.5秒<>。",
        "skill2": "圣银弩箭：被动技能，1级即可使用且始终生效。每第三次普通攻击造成额外的<#f5f5f5ff>固定伤害<>。",
        "ult": "终极时刻：在<#ffb900ff>10.0秒<>内，薇恩获得<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>50点攻击力<>、<i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20%移动速度<>、<i#asset/base/ui/banpick/champion_stat_icon:attack_speed_0><#ceff99ff>20%攻击速度<>，以及更快的技能冷却回复。终极时刻期间，闪避突袭会提供隐身。"
      },
      "bo_league_champions_fiddlesticks": {
        "name": "费德提克",
        "attack": "向目标掷出鸦形弹体，造成<i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的75%<>的<#a974ffff>魔法伤害<>。",
        "skill": "恐惧：向一名敌方英雄发射噩梦弹体，造成<#a974ffff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的70%<>的<#a974ffff>魔法伤害<>，并使其恐惧1.25秒。",
        "skill2": "五骨丰登：短暂汲取附近敌人，持续造成<#a974ffff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的25%<>的<#a974ffff>魔法伤害<>，每命中一名敌人就为费德提克回复<#6aff55ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#6aff55ff>法术强度的8%<>生命值。",
        "ult": "群鸦风暴：瞬移至一名敌方英雄身边，短暂恐惧附近敌方英雄，并使费德提克被风暴环绕2秒，持续对附近敌人造成<#a974ffff>26<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的30%<>的<#a974ffff>魔法伤害<>。"
      },
      "bo_league_champions_azir": {
        "name": "阿兹尔",
        "attack": "阿兹尔以沙之魔法攻击目标，造成<i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的75%<>的<#a974ffff>魔法伤害<>，并偶尔召唤沙兵加入战斗。",
        "skill": "沙兵现身：将一名沙兵派往目标位置，对经过的敌人造成<#a974ffff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的60%<>的<#a974ffff>魔法伤害<>。抵达后，沙兵会留下并攻击附近敌人，每次命中英雄造成<#a974ffff>15<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的70%<>的<#a974ffff>魔法伤害<>。",
        "skill2": "流沙移形：召唤一名沙兵并冲向它，获得<#ffb900ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的45%<>护盾。阿兹尔穿过的敌人受到<#a974ffff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的45%<>的<#a974ffff>魔法伤害<>。沙兵会在冲刺后留下。",
        "ult": "禁军之墙：向前方派出一道沙兵之墙，对路径上的敌人造成<#a974ffff>120<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的100%<>的<#a974ffff>魔法伤害<>，将其击退并短暂击飞。墙体会短暂留下，阻碍敌人穿过。"
      },
      "bo_league_champions_fizz": {
        "name": "菲兹",
        "attack": "近战攻击目标，造成<#a974ffff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>100%法术强度<>的<#a974ffff>魔法伤害<>。使用淘气打击后，普通攻击命中时会短暂施加毒素。",
        "skill": "淘气打击：冲过目标并落到其身后，造成<#a974ffff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>55%法术强度<>的<#a974ffff>魔法伤害<>，并使其<#ffb900ff>中毒3.0秒<>。命中后的<#ffb900ff>4.0秒<>内，菲兹的普通攻击命中时会施加较弱的毒素。",
        "skill2": "古灵 / 精怪：朝选定的敌方或友方方向撑杆跃起，在杆上短暂停留，期间<#ffb900ff>隐形、减免伤害并免疫控制2.4秒<>，随后短距离落下并溅击，造成<#a974ffff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>65%法术强度<>的<#a974ffff>魔法伤害<>，并使附近敌人<#ef5350ff>减速0.5秒<>。",
        "ult": "巨鲨强袭：向指定方向投出一条远距离小鱼。小鱼会停在命中的第一个敌方英雄身上，使其<#ef5350ff>严重减速2.5秒<>；若未命中，则会飞到路径终点。减速期间鲨鱼出现，随后跃出造成<#a974ffff>240<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>140%法术强度<>的<#a974ffff>魔法伤害<>，并将敌人<#ef5350ff>击飞<>。"
      },
      "bo_league_champions_ezreal": {
        "name": "伊泽瑞尔",
        "attack": "向目标发射能量弹，造成<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的100%<>的<#ff9028ff>物理伤害<>。",
        "skill": "秘术射击：向指定方向发射快速技能弹，在命中的第一个敌人处停止，并对英雄造成<#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的110%<>的<#ff9028ff>物理伤害<>。小兵受到一半伤害。",
        "skill2": "奥术跃迁：向指定方向闪现一小段距离。",
        "ult": "精准弹幕：向敌人方向发射无限距离攻击，对命中的敌人造成<#ff9028ff>220<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的110%<>的<#ff9028ff>物理伤害<>，并额外造成<i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的70%<>的<#a974ffff>魔法伤害<>。"
      },
      "test_mod_aatrox": {
        "name": "亚托克斯",
        "attack": "暗裔剑魔亚托克斯的赐死剑气：强化下一次巨剑攻击，造成<#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力112%<>的<#ff9028ff>物理伤害<>。",
        "skill": "Q - 暗裔利刃：每次施放只挥出一段剑招：第一段窄幅前刺，第二段横向宽扫，第三段重砸伤害更高并将敌人击飞<#ef5350ff>0.5秒<>。再次施放Q才会进入下一段，不会一次打出三段。",
        "skill2": "W - 恶火束链：亚托克斯向前发射恶火锁链，命中敌方英雄时造成伤害并<#ffb900ff>减速<>。短暂延迟后锁链收束，再次造成伤害并短暂束缚路径上的敌人。",
        "ult": "R - 大灭：亚托克斯释放恶魔形态，持续<#ffb900ff>10.0秒<>，获得<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75攻击力<>、<i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20%移动速度<>和<#6aff55ff>50%吸血<>。施放时短暂恐惧附近敌人。"
      },
      "test_mod_viktor": {
        "name": "维克托",
        "attack": "奥术先驱 / 机械先驱维克托：奥术脉冲造成<#a974ffff>12<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75%法术强度<>的魔法伤害。虹吸蓄能时下一次普攻造成<#a974ffff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>115%法术强度<>并获得护盾。光荣进化会强化后续技能。",
        "skill": "E - 海克斯射线：维克托的第三机械臂向指定方向发射激光，对直线敌人造成魔法伤害。进化后留下余震，造成伤害并短暂减速。命中敌方英雄会推进光荣进化。",
        "skill2": "Q/W - 虹吸能量 + 重力场：维克托获得护盾并强化下一次普攻，随后在目标位置制造重力场。区域内敌人被减速，停留到坍缩时会被眩晕；进化后还会干扰位移技能。",
        "ult": "R - 奥术风暴：维克托在目标位置召唤奥术风暴，造成初始爆发魔法伤害并干扰敌方技能，随后持续脉冲。施放奥术风暴会推进光荣进化；完全进化后范围更大、持续更久、脉冲更快。"
      },
      "test_mod_veigar": {
        "name": "维迦",
        "attack": "向目标发射一枚魔法弹，造成<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的100%<>的<#ff9028ff>物理伤害<>。",
        "skill": "短暂延迟后召唤暗物质从天而降，对<#ffb900ff>35范围<>内的敌人造成<#a974ffff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的180%<>的<#a974ffff>魔法伤害<>。命中敌方英雄可获得<i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>22点法术强度，直到死亡<>；小兵受到的伤害减半。",
        "skill2": "扭曲空间边缘，创造视界牢笼。<#ffb900ff>1.0秒<>后，牢笼内的敌方英雄被<#ef5350ff>晕眩1.5秒<>，随后牢笼消失。",
        "ult": "向一名敌方英雄释放一团暗黑魔法，造成<#a974ffff>150<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>法术强度的200%<>的<#a974ffff>魔法伤害<>。"
      },
      "test_mod_jhin": {
        "name": "烬",
        "attack": "向目标射出一发子弹，造成<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的100%<>的<#ff9028ff>物理伤害<>。每第四次攻击会使用红色子弹，造成<#ff9028ff>100<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的200%<>的伤害。射出第四发后，烬会装填弹药，在下一次攻击前攻击速度大幅降低。",
        "skill": "曼舞手雷：向范围内的一名敌人投掷一枚会弹跳的手雷。手雷可跳向附近另一名敌人，命中时造成<#ff9028ff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的75%<>的<#ff9028ff>物理伤害<>。",
        "skill2": "致命华彩：进行一次远程直线射击，对敌方英雄造成<#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的70%<>的<#ff9028ff>物理伤害<>，对小兵造成<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的30%<>的伤害。被命中的敌方英雄被<#ef5350ff>晕眩0.5秒<>。",
        "ult": "完美谢幕：烬架好武器，将自己固定在原地，向指定方向射出四发只对英雄生效的子弹。每发子弹在命中第一个敌方英雄时停下。前三发各造成<#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的150%<>的<#ff9028ff>物理伤害<>；威力更强的红色第四发子弹造成<#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的300%<>的伤害。"
      },
      "test_mod_vayne": {
        "name": "薇恩",
        "attack": "向目标射出一支弩箭，造成<i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的100%<>的<#ff9028ff>物理伤害<>。每第三次普通攻击会触发圣银弩箭，造成<#f5f5f5ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>攻击力的35%<> + <#f5f5f5ff>目标最大生命值的4%<>的<#f5f5f5ff>固定伤害<>。",
