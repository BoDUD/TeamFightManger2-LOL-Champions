      },
      "test_mod_ezreal": {
        "name": "Ezreal",
        "attack": "Fires an energy bolt at the target, dealing <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> as <#ff9028ff>physical damage<>.",
        "skill": "Mystic Shot: fires a fast skillshot in the chosen direction, stopping on the first enemy hit and dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as <#ff9028ff>physical damage<> to champions. Minions take half damage.",
        "skill2": "Arcane Shift: blinks a short distance in the chosen direction.",
        "ult": "Trueshot Barrage: fires an unlimited-range attack toward enemies, dealing <#ff9028ff>220<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as <#ff9028ff>physical damage<>, plus <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>70% AP<> as <#a974ffff>magic damage<> to enemies hit."
      },
      "bo_league_champions_kayn": {
        "name": "Kayn (Shadow Reaper)",
        "attack": "Shadow Reaper - Darkin Scythe: Kayn sweeps with his scythe, dealing <#ff9028ff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>105% attack damage<> as physical damage. While Darkin Ascension is active, the strike hits harder and heals Kayn.",
        "skill": "Q - Reaping Slash: Kayn dashes a short distance and slashes in front of him, dealing <#ff9028ff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>85% attack damage<> physical damage. Darkin Ascension empowers the slash.",
        "skill2": "W - Blade's Reach: Kayn carves a long line with his scythe, dealing <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> physical damage and <#ffb900ff>slowing enemies for 1.0s<>. In Darkin Ascension it is wider and briefly knocks enemies airborne.",
        "ult": "R - Umbral Trespass: Kayn enters an enemy champion, becoming untargetable for a short moment, then bursts out to deal <#ff9028ff>180<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>160% attack damage<> physical damage and gains Darkin Ascension for <#ffb900ff>10.0s<>."
      },
      "test_mod_kayn": {
        "name": "Kayn (Shadow Reaper)",
        "attack": "Shadow Reaper - Darkin Scythe: Kayn sweeps with his scythe, dealing <#ff9028ff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>105% attack damage<> as physical damage. While Darkin Ascension is active, the strike hits harder and heals Kayn.",
        "skill": "Q - Reaping Slash: Kayn dashes a short distance and slashes in front of him, dealing <#ff9028ff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>85% attack damage<> physical damage. Darkin Ascension empowers the slash.",
        "skill2": "W - Blade's Reach: Kayn carves a long line with his scythe, dealing <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> physical damage and <#ffb900ff>slowing enemies for 1.0s<>. In Darkin Ascension it is wider and briefly knocks enemies airborne.",
        "ult": "R - Umbral Trespass: Kayn enters an enemy champion, becoming untargetable for a short moment, then bursts out to deal <#ff9028ff>180<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>160% attack damage<> physical damage and gains Darkin Ascension for <#ffb900ff>10.0s<>."
      },
      "bo_league_champions_yasuo": {
        "name": "Yasuo (Unforgiven)",
        "attack": "Way of the Wanderer: Yasuo slashes with his katana, dealing <#ff9028ff>8<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> physical damage. Every third basic attack grants a short Flow shield.",
        "skill": "Q - Steel Tempest: each cast thrusts a wind blade forward, dealing <#ff9028ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% attack damage<>. The second Q is stronger. The third Q fires a tornado that knocks enemies airborne and readies Last Breath.",
        "skill2": "W/E - Sweeping Blade + Wind Wall: Yasuo dashes through the chosen direction, slicing enemies for <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>55% attack damage<>, gaining a small shield, then raises a wind wall that blocks movement skills and pushes enemies back.",
        "ult": "R - Last Breath: Yasuo blinks behind an enemy champion and strikes for <#ff9028ff>110<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>120% attack damage<>. If Steel Tempest tornado recently hit, Last Breath becomes empowered, dealing higher damage in an area and knocking enemies airborne."
      },
      "test_mod_yasuo": {
        "name": "Yasuo (Unforgiven)",
        "attack": "Way of the Wanderer: Yasuo slashes with his katana, dealing <#ff9028ff>8<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> physical damage. Every third basic attack grants a short Flow shield.",
        "skill": "Q - Steel Tempest: each cast thrusts a wind blade forward, dealing <#ff9028ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% attack damage<>. The second Q is stronger. The third Q fires a tornado that knocks enemies airborne and readies Last Breath.",
        "skill2": "W/E - Sweeping Blade + Wind Wall: Yasuo dashes through the chosen direction, slicing enemies for <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>55% attack damage<>, gaining a small shield, then raises a wind wall that blocks movement skills and pushes enemies back.",
        "ult": "R - Last Breath: Yasuo blinks behind an enemy champion and strikes for <#ff9028ff>110<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>120% attack damage<>. If Steel Tempest tornado recently hit, Last Breath becomes empowered, dealing higher damage in an area and knocking enemies airborne."
      },
      "bo_league_champions_jinx": {
        "name": "Jinx (Loose Cannon)",
        "attack": "Pow-Pow / Fishbones: basic attacks default to Pow-Pow and build minigun attack speed. During the short Fishbones window, attacks become splash rockets and clear Pow-Pow stacks.",
        "skill": "Switcheroo!: when an enemy target is available, Jinx briefly swaps to Fishbones for splash rocket attacks, then automatically returns to Pow-Pow.",
        "skill2": "Zap! + Flame Chompers!: fires a long electric shot that damages and slows, then throws Flame Chompers ahead to bite, stun, and burn enemies caught in the line.",
        "ult": "Super Mega Death Rocket!: fires a huge shark rocket across the map. On champion hit it explodes, deals heavy physical damage, and triggers Get Excited movement and attack speed."
      },
      "test_mod_jinx": {
        "name": "Jinx (Loose Cannon)",
        "attack": "Pow-Pow / Fishbones: basic attacks default to Pow-Pow and build minigun attack speed. During the short Fishbones window, attacks become splash rockets and clear Pow-Pow stacks.",
        "skill": "Switcheroo!: when an enemy target is available, Jinx briefly swaps to Fishbones for splash rocket attacks, then automatically returns to Pow-Pow.",
        "skill2": "Zap! + Flame Chompers!: fires a long electric shot that damages and slows, then throws Flame Chompers ahead to bite, stun, and burn enemies caught in the line.",
        "ult": "Super Mega Death Rocket!: fires a huge shark rocket across the map. On champion hit it explodes, deals heavy physical damage, and triggers Get Excited movement and attack speed."
      },
      "bo_league_champions_thresh": {
        "name": "Thresh (Chain Warden)",
        "attack": "Damnation / Flay chain: Thresh lashes with his chain scythe for <#ff9028ff>physical damage<> and a small <#a974ffff>magic burn<>. Every third basic attack becomes an empowered soul lash that slows the target and resets the chain-charge cycle.",
        "skill": "Q - Death Sentence: Thresh throws a non-piercing hook chain in a long line. The first enemy hit takes <#a974ffff>65<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> magic damage, is stunned, heavily slowed, and has movement skills briefly blocked. Champion hits grant a permanent Damnation soul stack.",
        "skill2": "W/E - Dark Passage / Flay: Thresh lights his lantern to shield himself, then sweeps the chain scythe forward. Enemies hit take magic damage, are pushed back, slowed, and grant a Damnation soul stack on champion hit.",
        "ult": "R - The Box: Thresh summons spectral prison walls around himself. Enemies inside take heavy magic damage, are strongly slowed, and have movement skills briefly blocked. The Box lingers as a slowing field, and champion hits grant permanent souls."
      },
      "test_mod_thresh": {
        "name": "Thresh (Chain Warden)",
        "attack": "Damnation / Flay chain: Thresh lashes with his chain scythe for <#ff9028ff>physical damage<> and a small <#a974ffff>magic burn<>. Every third basic attack becomes an empowered soul lash that slows the target and resets the chain-charge cycle.",
        "skill": "Q - Death Sentence: Thresh throws a non-piercing hook chain in a long line. The first enemy hit takes <#a974ffff>65<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> magic damage, is stunned, heavily slowed, and has movement skills briefly blocked. Champion hits grant a permanent Damnation soul stack.",
        "skill2": "W/E - Dark Passage / Flay: Thresh lights his lantern to shield himself, then sweeps the chain scythe forward. Enemies hit take magic damage, are pushed back, slowed, and grant a Damnation soul stack on champion hit.",
        "ult": "R - The Box: Thresh summons spectral prison walls around himself. Enemies inside take heavy magic damage, are strongly slowed, and have movement skills briefly blocked. The Box lingers as a slowing field, and champion hits grant permanent souls."
      },
      "bo_league_champions_darius": {
        "name": "Darius",
        "attack": "Hemorrhage: Darius, the Hand of Noxus, cleaves with his axe for <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as physical damage and advances Hemorrhage. At five stacks he gains Noxian Might. If Crippling Strike is primed, the next attack deals heavier damage and <#ef5350ff>slows<> the target.",
        "skill": "Q - Decimate: Darius spins his axe in a red outer circle, dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> as physical damage, applying Hemorrhage, and healing himself when enemies are struck. During Noxian Might, Decimate deals more damage and heals more.",
        "skill2": "E/W - Apprehend and Crippling Strike: Darius sweeps his axe forward in a chain-like hook line, dealing <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>60% attack damage<>, briefly stunning, slowing, and blocking movement skills. The cast primes his next attack as Crippling Strike.",
        "ult": "R - Noxian Guillotine: Darius rushes behind an enemy champion and executes with true damage. The blow scales with Hemorrhage stacks, reaches its highest damage at five stacks or during Noxian Might, and plays Darius's Noxian Guillotine voice line."
      },
      "test_mod_darius": {
        "name": "Darius",
        "attack": "Hemorrhage: Darius, the Hand of Noxus, cleaves with his axe for <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as physical damage and advances Hemorrhage. At five stacks he gains Noxian Might. If Crippling Strike is primed, the next attack deals heavier damage and <#ef5350ff>slows<> the target.",
        "skill": "Q - Decimate: Darius spins his axe in a red outer circle, dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> as physical damage, applying Hemorrhage, and healing himself when enemies are struck. During Noxian Might, Decimate deals more damage and heals more.",
        "skill2": "E/W - Apprehend and Crippling Strike: Darius sweeps his axe forward in a chain-like hook line, dealing <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>60% attack damage<>, briefly stunning, slowing, and blocking movement skills. The cast primes his next attack as Crippling Strike.",
        "ult": "R - Noxian Guillotine: Darius rushes behind an enemy champion and executes with true damage. The blow scales with Hemorrhage stacks, reaches its highest damage at five stacks or during Noxian Might, and plays Darius's Noxian Guillotine voice line."
      }
    }
  },
  "ru": {
    "description": {
      "bo_league_champions_aatrox": {
        "name": "Aatrox",
        "attack": "Deathbringer Stance: empowers the next greatsword strike, dealing <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>112% attack damage<> as <#ff9028ff>physical damage<>.",
        "skill": "Q - The Darkin Blade: each cast releases one strike of Aatrox's three-part blade combo. Q1 is a narrow thrust, Q2 is a wide cleave, and Q3 is a heavy smash that hits hardest and <#ef5350ff>knocks enemies airborne for 0.5s<>. Casting Q again advances to the next strike instead of firing all three at once.",
        "skill2": "W - Infernal Chains: Aatrox fires a demonic chain in a line, damaging and <#ffb900ff>slowing<> enemy champions hit. After a short delay the chain snaps back, dealing damage again and briefly locking enemies caught in the path.",
        "ult": "R - World Ender: Aatrox reveals his demonic form for <#ffb900ff>10.0s<>, gaining <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75 attack damage<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% movement speed<> and <#6aff55ff>50% vamp<>. Nearby enemies are briefly feared on cast."
      },
      "bo_league_champions_viktor": {
        "name": "Viktor",
        "attack": "Arcane Pulse: Viktor fires an arcane bolt, dealing <#a974ffff>12<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> as magic damage. While Siphon Empower is active, his next basic attack deals <#a974ffff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>115% magic power<> and grants Viktor a shield.",
        "skill": "E - Hextech Ray: Viktor's third arm fires a laser in the target direction, dealing magic damage to enemies in a line. When evolved, the ray leaves an aftershock that detonates shortly after, damaging and briefly slowing enemies. Hitting an enemy champion advances Glorious Evolution.",
        "skill2": "Q/W - Siphon Power + Gravity Field: Viktor shields himself and empowers his next basic attack, then creates a gravity field at the target location. Enemies inside are slowed; enemies still in the field when it collapses are stunned. When evolved, the field also disrupts movement skills.",
        "ult": "R - Arcane Storm: Viktor summons an arcane storm at the target location, dealing an initial burst of magic damage and disrupting enemy skills. The storm then pulses repeatedly. Casting Arcane Storm advances Glorious Evolution; once fully evolved, the storm is larger, lasts longer, and pulses faster."
      },
      "bo_league_champions_veigar": {
        "name": "Вейгар",
        "attack": "Выпускает магический снаряд в цель, нанося <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% силы атаки<> в виде <#ff9028ff>физического урона<>.",
        "skill": "После короткой задержки обрушивает темную материю в выбранную точку, нанося <#a974ffff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>180% AP<> <#a974ffff>магического урона<> в <#ffb900ff>радиусе 35<>. Попадание по вражескому чемпиону дает <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>22 AP до смерти<>; миньоны получают половину урона.",
        "skill2": "Создает клетку Горизонта событий. Через <#ffb900ff>1.0 сек.<> вражеские чемпионы внутри <#ef5350ff>оглушаются на 1.5 сек.<> и клетка исчезает.",
        "ult": "Выпускает сгусток темной магии во вражеского чемпиона, нанося <#a974ffff>150<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>200% AP<> <#a974ffff>магического урона<>."
      },
      "bo_league_champions_jhin": {
        "name": "Джин",
        "attack": "Стреляет в цель, нанося <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% силы атаки<> в виде <#ff9028ff>физического урона<>. Каждая четвертая атака использует красный снаряд и наносит <#ff9028ff>100<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>200% силы атаки<>. После четвертого выстрела Джин перезаряжается с сильно сниженной скоростью атаки до следующей атаки.",
        "skill": "Танцующая граната: бросает отскакивающую гранату во врага в пределах дальности. Граната может перескочить на другого ближайшего врага и при попадании наносит <#ff9028ff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75% силы атаки<> в виде <#ff9028ff>физического урона<>.",
        "skill2": "Смертельный блеск: выпускает длинный линейный выстрел, нанося вражеским чемпионам <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% силы атаки<> в виде <#ff9028ff>физического урона<> и миньонам <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>30% силы атаки<>. Попавшие вражеские чемпионы <#ef5350ff>оглушаются на 0.5 сек.<>.",
        "ult": "Последний поклон: приковывает Джина к месту и выпускает четыре пули, действующие только на чемпионов, в выбранном направлении. Каждая пуля останавливается при попадании в первого вражеского чемпиона. Первые три выстрела наносят <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% силы атаки<> в виде <#ff9028ff>физического урона<>; более крупный красный четвертый выстрел наносит <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>300% силы атаки<>."
      },
      "bo_league_champions_vayne": {
        "name": "Вейн",
        "attack": "Стреляет в цель арбалетным болтом, нанося <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% силы атаки<> в виде <#ff9028ff>физического урона<>. Каждая третья базовая атака активирует Серебряные болты, нанося <#f5f5f5ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>35% силы атаки<> + <#f5f5f5ff>4% от максимального здоровья цели<> в виде <#f5f5f5ff>фиксированного урона<>.",
        "skill": "Кувырок: перекатывается на короткое расстояние в выбранном направлении и усиливает следующую базовую атаку, чтобы она нанесла <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% силы атаки<>. Во время Последнего часа Кувырок проходит дальше и делает Вейн <#ffb900ff>невидимой на 1.5 сек.<>.",
        "skill2": "Серебряные болты: пассивное умение, доступно с 1 уровня и всегда активно. Каждая третья базовая атака наносит дополнительный <#f5f5f5ff>фиксированный урон<>.",
        "ult": "Последний час: на <#ffb900ff>10.0 сек.<> Вейн получает <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>50 силы атаки<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% скорости передвижения<>, <i#asset/base/ui/banpick/champion_stat_icon:attack_speed_0><#ceff99ff>20% скорости атаки<> и ускоренное восстановление умений. Пока эффект активен, Кувырок дает невидимость."
      },
      "bo_league_champions_fiddlesticks": {
        "name": "Фиддлстикс",
        "attack": "Бросает в цель снаряд в форме ворона, нанося <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% AP<> в виде <#a974ffff>магического урона<>.",
        "skill": "Устрашение: посылает кошмарный снаряд во вражеского чемпиона, нанося <#a974ffff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>70% AP<> <#a974ffff>магического урона<> и пугая его на 1.25 секунды.",
        "skill2": "Обильная жатва: ненадолго высасывает силы из ближайших врагов, многократно нанося <#a974ffff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>25% AP<> <#a974ffff>магического урона<> и исцеляя Фиддлстикса на <#6aff55ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#6aff55ff>8% AP<> за каждого пораженного врага.",
        "ult": "Воронья буря: переносится к вражескому чемпиону, ненадолго пугает ближайших вражеских чемпионов и окружает Фиддлстикса бурей на 2 секунды, многократно нанося ближайшим врагам <#a974ffff>26<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>30% AP<> <#a974ffff>магического урона<>."
      },
      "bo_league_champions_azir": {
        "name": "Азир",
        "attack": "Азир направляет песчаную магию в цель, нанося 75% AP магического урона и иногда призывая песчаных солдат, которые вступают в бой.",
        "skill": "Восстаньте!: отправляет песчаного солдата в выбранную точку, нанося 30 + 60% AP магического урона врагам, через которых он проходит. Прибыв, солдат остается и атакует ближайших врагов, нанося чемпионам 15 + 70% AP магического урона за удар.",
        "skill2": "Зыбучие пески: призывает песчаного солдата и совершает рывок к нему, получая щит 70 + 45% AP. Враги, через которых проходит Азир, получают 40 + 45% AP магического урона. Солдат остается после рывка.",
        "ult": "Императорский раздел: посылает стену солдат вперед, нанося врагам на пути 120 + 100% AP магического урона, отталкивая их и ненадолго подбрасывая. Стена недолго остается и мешает проходить через нее."
      },
      "bo_league_champions_fizz": {
        "name": "Физз",
        "attack": "Бьет цель в ближнем бою, нанося <#a974ffff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>100% AP<> <#a974ffff>магического урона<>. После Удара морского ежа базовые атаки ненадолго накладывают яд при попадании.",
        "skill": "Удар морского ежа: проносится сквозь цель и приземляется за ней, нанося <#a974ffff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>55% AP<> <#a974ffff>магического урона<> и отравляя ее на <#ffb900ff>3.0 сек.<>. В течение <#ffb900ff>4.0 сек.<> после попадания базовые атаки Физза накладывают более слабый яд при попадании.",
        "skill2": "Игривый / Обманщик: прыгает в выбранном направлении к врагу или союзнику, ненадолго задерживаясь на шесте, пока он <#ffb900ff>невидим, получает сниженный урон и невосприимчив к контролю на 2.4 сек.<>, затем делает короткий спуск и падает, нанося <#a974ffff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>65% AP<> <#a974ffff>магического урона<> и <#ef5350ff>замедляя ближайших врагов на 0.5 сек.<>.",
        "ult": "Наживка для акулы: бросает дальнобойную рыбу в выбранном направлении. Рыба останавливается на первом пораженном вражеском чемпионе и <#ef5350ff>сильно замедляет его на 2.5 сек.<>; если промахивается, достигает конца пути. Во время замедления появляется акула, затем вырывается наружу, нанося <#a974ffff>240<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>140% AP<> <#a974ffff>магического урона<> и <#ef5350ff>подбрасывая врагов<>."
      },
      "bo_league_champions_ezreal": {
        "name": "Эзреаль",
        "attack": "Выпускает энергетический снаряд в цель, нанося <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% силы атаки<> в виде <#ff9028ff>физического урона<>.",
        "skill": "Мистический выстрел: выпускает быстрый скиллшот в выбранном направлении, останавливается на первом пораженном враге и наносит чемпионам <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% силы атаки<> в виде <#ff9028ff>физического урона<>. Миньоны получают половину урона.",
        "skill2": "Магический сдвиг: переносится на короткое расстояние в выбранном направлении.",
        "ult": "Точный залп: выпускает атаку с неограниченной дальностью в сторону врагов, нанося пораженным врагам <#ff9028ff>220<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% силы атаки<> в виде <#ff9028ff>физического урона<>, плюс <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>70% AP<> в виде <#a974ffff>магического урона<>."
      },
      "test_mod_aatrox": {
        "name": "Aatrox",
        "attack": "Deathbringer Stance: empowers the next greatsword strike, dealing <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>112% attack damage<> as <#ff9028ff>physical damage<>.",
        "skill": "Q - The Darkin Blade: each cast releases one strike of Aatrox's three-part blade combo. Q1 is a narrow thrust, Q2 is a wide cleave, and Q3 is a heavy smash that hits hardest and <#ef5350ff>knocks enemies airborne for 0.5s<>. Casting Q again advances to the next strike instead of firing all three at once.",
        "skill2": "W - Infernal Chains: Aatrox fires a demonic chain in a line, damaging and <#ffb900ff>slowing<> enemy champions hit. After a short delay the chain snaps back, dealing damage again and briefly locking enemies caught in the path.",
        "ult": "R - World Ender: Aatrox reveals his demonic form for <#ffb900ff>10.0s<>, gaining <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75 attack damage<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% movement speed<> and <#6aff55ff>50% vamp<>. Nearby enemies are briefly feared on cast."
      },
      "test_mod_viktor": {
        "name": "Viktor",
        "attack": "Arcane Pulse: Viktor fires an arcane bolt, dealing <#a974ffff>12<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> as magic damage. While Siphon Empower is active, his next basic attack deals <#a974ffff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>115% magic power<> and grants Viktor a shield.",
        "skill": "E - Hextech Ray: Viktor's third arm fires a laser in the target direction, dealing magic damage to enemies in a line. When evolved, the ray leaves an aftershock that detonates shortly after, damaging and briefly slowing enemies. Hitting an enemy champion advances Glorious Evolution.",
        "skill2": "Q/W - Siphon Power + Gravity Field: Viktor shields himself and empowers his next basic attack, then creates a gravity field at the target location. Enemies inside are slowed; enemies still in the field when it collapses are stunned. When evolved, the field also disrupts movement skills.",
        "ult": "R - Arcane Storm: Viktor summons an arcane storm at the target location, dealing an initial burst of magic damage and disrupting enemy skills. The storm then pulses repeatedly. Casting Arcane Storm advances Glorious Evolution; once fully evolved, the storm is larger, lasts longer, and pulses faster."
      },
      "test_mod_veigar": {
        "name": "Вейгар",
        "attack": "Выпускает магический снаряд в цель, нанося <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% силы атаки<> в виде <#ff9028ff>физического урона<>.",
        "skill": "После короткой задержки обрушивает темную материю в выбранную точку, нанося <#a974ffff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>180% AP<> <#a974ffff>магического урона<> в <#ffb900ff>радиусе 35<>. Попадание по вражескому чемпиону дает <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>22 AP до смерти<>; миньоны получают половину урона.",
        "skill2": "Создает клетку Горизонта событий. Через <#ffb900ff>1.0 сек.<> вражеские чемпионы внутри <#ef5350ff>оглушаются на 1.5 сек.<> и клетка исчезает.",
        "ult": "Выпускает сгусток темной магии во вражеского чемпиона, нанося <#a974ffff>150<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>200% AP<> <#a974ffff>магического урона<>."
      },
      "test_mod_jhin": {
        "name": "Джин",
        "attack": "Стреляет в цель, нанося <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% силы атаки<> в виде <#ff9028ff>физического урона<>. Каждая четвертая атака использует красный снаряд и наносит <#ff9028ff>100<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>200% силы атаки<>. После четвертого выстрела Джин перезаряжается с сильно сниженной скоростью атаки до следующей атаки.",
        "skill": "Танцующая граната: бросает отскакивающую гранату во врага в пределах дальности. Граната может перескочить на другого ближайшего врага и при попадании наносит <#ff9028ff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75% силы атаки<> в виде <#ff9028ff>физического урона<>.",
        "skill2": "Смертельный блеск: выпускает длинный линейный выстрел, нанося вражеским чемпионам <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% силы атаки<> в виде <#ff9028ff>физического урона<> и миньонам <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>30% силы атаки<>. Попавшие вражеские чемпионы <#ef5350ff>оглушаются на 0.5 сек.<>.",
        "ult": "Последний поклон: приковывает Джина к месту и выпускает четыре пули, действующие только на чемпионов, в выбранном направлении. Каждая пуля останавливается при попадании в первого вражеского чемпиона. Первые три выстрела наносят <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% силы атаки<> в виде <#ff9028ff>физического урона<>; более крупный красный четвертый выстрел наносит <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>300% силы атаки<>."
      },
      "test_mod_vayne": {
        "name": "Вейн",
        "attack": "Стреляет в цель арбалетным болтом, нанося <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% силы атаки<> в виде <#ff9028ff>физического урона<>. Каждая третья базовая атака активирует Серебряные болты, нанося <#f5f5f5ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>35% силы атаки<> + <#f5f5f5ff>4% от максимального здоровья цели<> в виде <#f5f5f5ff>фиксированного урона<>.",
        "skill": "Кувырок: перекатывается на короткое расстояние в выбранном направлении и усиливает следующую базовую атаку, чтобы она нанесла <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% силы атаки<>. Во время Последнего часа Кувырок проходит дальше и делает Вейн <#ffb900ff>невидимой на 1.5 сек.<>.",
        "skill2": "Серебряные болты: пассивное умение, доступно с 1 уровня и всегда активно. Каждая третья базовая атака наносит дополнительный <#f5f5f5ff>фиксированный урон<>.",
        "ult": "Последний час: на <#ffb900ff>10.0 сек.<> Вейн получает <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>50 силы атаки<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% скорости передвижения<>, <i#asset/base/ui/banpick/champion_stat_icon:attack_speed_0><#ceff99ff>20% скорости атаки<> и ускоренное восстановление умений. Пока эффект активен, Кувырок дает невидимость."
      },
      "test_mod_fiddlesticks": {
        "name": "Фиддлстикс",
        "attack": "Бросает в цель снаряд в форме ворона, нанося <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% AP<> в виде <#a974ffff>магического урона<>.",
        "skill": "Устрашение: посылает кошмарный снаряд во вражеского чемпиона, нанося <#a974ffff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>70% AP<> <#a974ffff>магического урона<> и пугая его на 1.25 секунды.",
        "skill2": "Обильная жатва: ненадолго высасывает силы из ближайших врагов, многократно нанося <#a974ffff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>25% AP<> <#a974ffff>магического урона<> и исцеляя Фиддлстикса на <#6aff55ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#6aff55ff>8% AP<> за каждого пораженного врага.",
        "ult": "Воронья буря: переносится к вражескому чемпиону, ненадолго пугает ближайших вражеских чемпионов и окружает Фиддлстикса бурей на 2 секунды, многократно нанося ближайшим врагам <#a974ffff>26<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>30% AP<> <#a974ffff>магического урона<>."
      },
