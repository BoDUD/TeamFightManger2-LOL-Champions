      },
      "test_mod_kayn": {
        "name": "Kayn (Shadow Reaper)",
        "attack": "Shadow Reaper - Darkin Scythe: Kayn sweeps with his scythe, dealing <#ff9028ff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>105% attack damage<> as physical damage. While Darkin Ascension is active, the strike hits harder and heals Kayn.",
        "skill": "Q - Reaping Slash: Kayn dashes a short distance and slashes in front of him, dealing <#ff9028ff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>85% attack damage<> physical damage. Darkin Ascension empowers the slash.",
        "skill2": "W - Blade's Reach: Kayn carves a long line with his scythe, dealing <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> physical damage and <#ffb900ff>slowing enemies for 1.0s<>. In Darkin Ascension it is wider and briefly knocks enemies airborne.",
        "ult": "R - Umbral Trespass: Kayn enters an enemy champion, becoming untargetable for a short moment, then bursts out to deal <#ff9028ff>180<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>160% attack damage<> physical damage and gains Darkin Ascension for <#ffb900ff>10.0s<>."
      },
      "bo_league_champions_yasuo": {
        "name": "Yasuo (Unforgiven)",
        "attack": "Way of the Wanderer: Yasuo slashes with his katana, dealing <#ff9028ff>8<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> physical damage. Every third basic attack grants a short Flow shield.",
        "skill": "Q - Steel Tempest: each cast thrusts a wind blade forward, dealing <#ff9028ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% attack damage<>. The second Q is stronger. The third Q fires a tornado that knocks enemies airborne and readies Last Breath.",
        "skill2": "W/E - Sweeping Blade + Wind Wall: Yasuo dashes through the chosen direction, slicing enemies for <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>55% attack damage<>, gaining a small shield, then raises a wind wall that blocks movement skills and pushes enemies back.",
        "ult": "R - Last Breath: Yasuo blinks behind an enemy champion and strikes for <#ff9028ff>110<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>120% attack damage<>. If Steel Tempest tornado recently hit, Last Breath becomes empowered, dealing higher damage in an area and knocking enemies airborne."
      },
      "test_mod_yasuo": {
        "name": "Yasuo (Unforgiven)",
        "attack": "Way of the Wanderer: Yasuo slashes with his katana, dealing <#ff9028ff>8<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> physical damage. Every third basic attack grants a short Flow shield.",
        "skill": "Q - Steel Tempest: each cast thrusts a wind blade forward, dealing <#ff9028ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% attack damage<>. The second Q is stronger. The third Q fires a tornado that knocks enemies airborne and readies Last Breath.",
        "skill2": "W/E - Sweeping Blade + Wind Wall: Yasuo dashes through the chosen direction, slicing enemies for <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>55% attack damage<>, gaining a small shield, then raises a wind wall that blocks movement skills and pushes enemies back.",
        "ult": "R - Last Breath: Yasuo blinks behind an enemy champion and strikes for <#ff9028ff>110<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>120% attack damage<>. If Steel Tempest tornado recently hit, Last Breath becomes empowered, dealing higher damage in an area and knocking enemies airborne."
      },
      "bo_league_champions_jinx": {
        "name": "Jinx (Loose Cannon)",
        "attack": "Pow-Pow / Fishbones: basic attacks default to Pow-Pow and build minigun attack speed. During the short Fishbones window, attacks become splash rockets and clear Pow-Pow stacks.",
        "skill": "Switcheroo!: when an enemy target is available, Jinx briefly swaps to Fishbones for splash rocket attacks, then automatically returns to Pow-Pow.",
        "skill2": "Zap! + Flame Chompers!: fires a long electric shot that damages and slows, then throws Flame Chompers ahead to bite, stun, and burn enemies caught in the line.",
        "ult": "Super Mega Death Rocket!: fires a huge shark rocket across the map. On champion hit it explodes, deals heavy physical damage, and triggers Get Excited movement and attack speed."
      },
      "test_mod_jinx": {
        "name": "Jinx (Loose Cannon)",
        "attack": "Pow-Pow / Fishbones: basic attacks default to Pow-Pow and build minigun attack speed. During the short Fishbones window, attacks become splash rockets and clear Pow-Pow stacks.",
        "skill": "Switcheroo!: when an enemy target is available, Jinx briefly swaps to Fishbones for splash rocket attacks, then automatically returns to Pow-Pow.",
        "skill2": "Zap! + Flame Chompers!: fires a long electric shot that damages and slows, then throws Flame Chompers ahead to bite, stun, and burn enemies caught in the line.",
        "ult": "Super Mega Death Rocket!: fires a huge shark rocket across the map. On champion hit it explodes, deals heavy physical damage, and triggers Get Excited movement and attack speed."
      },
      "bo_league_champions_thresh": {
        "name": "Thresh",
        "attack": "Damnation / Flay chain: Chain Warden Thresh lashes with his chain scythe for <#ff9028ff>physical damage<> and a small <#a974ffff>magic burn<>. Every third basic attack becomes an empowered soul lash that slows the target and resets the chain-charge cycle.",
        "skill": "Q - Death Sentence: Thresh throws a non-piercing hook chain in a long line. The first enemy hit takes <#a974ffff>65<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> magic damage, is stunned, heavily slowed, and has movement skills briefly blocked. Champion hits grant a permanent Damnation soul stack.",
        "skill2": "W/E - Dark Passage / Flay: Thresh lights his lantern to shield himself, then sweeps the chain scythe forward. Enemies hit take magic damage, are pushed back, slowed, and grant a Damnation soul stack on champion hit.",
        "ult": "R - The Box: Thresh summons spectral prison walls around himself. Enemies inside take heavy magic damage, are strongly slowed, and have movement skills briefly blocked. The Box lingers as a slowing field, and champion hits grant permanent souls."
      },
      "test_mod_thresh": {
        "name": "Thresh",
        "attack": "Damnation / Flay chain: Chain Warden Thresh lashes with his chain scythe for <#ff9028ff>physical damage<> and a small <#a974ffff>magic burn<>. Every third basic attack becomes an empowered soul lash that slows the target and resets the chain-charge cycle.",
        "skill": "Q - Death Sentence: Thresh throws a non-piercing hook chain in a long line. The first enemy hit takes <#a974ffff>65<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> magic damage, is stunned, heavily slowed, and has movement skills briefly blocked. Champion hits grant a permanent Damnation soul stack.",
        "skill2": "W/E - Dark Passage / Flay: Thresh lights his lantern to shield himself, then sweeps the chain scythe forward. Enemies hit take magic damage, are pushed back, slowed, and grant a Damnation soul stack on champion hit.",
        "ult": "R - The Box: Thresh summons spectral prison walls around himself. Enemies inside take heavy magic damage, are strongly slowed, and have movement skills briefly blocked. The Box lingers as a slowing field, and champion hits grant permanent souls."
      },
      "bo_league_champions_darius": {
        "name": "Darius",
        "attack": "Hemorrhage: Darius, the Hand of Noxus, cleaves with his axe for <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as physical damage and advances Hemorrhage. At five stacks he gains Noxian Might. If Crippling Strike is primed, the next attack deals heavier damage and <#ef5350ff>slows<> the target.",
        "skill": "Q - Decimate: Darius spins his axe in a red outer circle, dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> as physical damage, applying Hemorrhage, and healing himself when enemies are struck. During Noxian Might, Decimate deals more damage and heals more.",
        "skill2": "E/W - Apprehend and Crippling Strike: Darius sweeps his axe forward in a chain-like hook line, dealing <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>60% attack damage<>, briefly stunning, slowing, and blocking movement skills. The cast primes his next attack as Crippling Strike.",
        "ult": "R - Noxian Guillotine: Darius rushes behind an enemy champion and executes with true damage. The blow scales with Hemorrhage stacks, reaches its highest damage at five stacks or during Noxian Might, and plays Darius's Noxian Guillotine voice line."
      },
      "test_mod_darius": {
        "name": "Darius",
        "attack": "Hemorrhage: Darius, the Hand of Noxus, cleaves with his axe for <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as physical damage and advances Hemorrhage. At five stacks he gains Noxian Might. If Crippling Strike is primed, the next attack deals heavier damage and <#ef5350ff>slows<> the target.",
        "skill": "Q - Decimate: Darius spins his axe in a red outer circle, dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> as physical damage, applying Hemorrhage, and healing himself when enemies are struck. During Noxian Might, Decimate deals more damage and heals more.",
        "skill2": "E/W - Apprehend and Crippling Strike: Darius sweeps his axe forward in a chain-like hook line, dealing <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>60% attack damage<>, briefly stunning, slowing, and blocking movement skills. The cast primes his next attack as Crippling Strike.",
        "ult": "R - Noxian Guillotine: Darius rushes behind an enemy champion and executes with true damage. The blow scales with Hemorrhage stacks, reaches its highest damage at five stacks or during Noxian Might, and plays Darius's Noxian Guillotine voice line."
      }
    }
  },
  "ja": {
    "description": {
      "bo_league_champions_aatrox": {
        "name": "Aatrox",
        "attack": "Deathbringer Stance: empowers the next greatsword strike, dealing <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>112% attack damage<> as <#ff9028ff>physical damage<>.",
        "skill": "Q - The Darkin Blade: each cast releases one strike of Aatrox's three-part blade combo. Q1 is a narrow thrust, Q2 is a wide cleave, and Q3 is a heavy smash that hits hardest and <#ef5350ff>knocks enemies airborne for 0.5s<>. Casting Q again advances to the next strike instead of firing all three at once.",
        "skill2": "W - Infernal Chains: Aatrox fires a demonic chain in a line, damaging and <#ffb900ff>slowing<> enemy champions hit. After a short delay the chain snaps back, dealing damage again and briefly locking enemies caught in the path.",
        "ult": "R - World Ender: Aatrox reveals his demonic form for <#ffb900ff>10.0s<>, gaining <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75 attack damage<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% movement speed<> and <#6aff55ff>50% vamp<>. Nearby enemies are briefly feared on cast."
      },
      "bo_league_champions_viktor": {
        "name": "Viktor",
        "attack": "Herald of the Arcane - Arcane Pulse: Viktor fires an arcane bolt, dealing <#a974ffff>12<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> as magic damage. While Siphon Empower is active, his next basic attack deals <#a974ffff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>115% magic power<> and grants Viktor a shield.",
        "skill": "E - Hextech Ray: Viktor's third arm fires a laser in the target direction, dealing magic damage to enemies in a line. When evolved, the ray leaves an aftershock that detonates shortly after, damaging and briefly slowing enemies. Hitting an enemy champion advances Glorious Evolution.",
        "skill2": "Q/W - Siphon Power + Gravity Field: Viktor shields himself and empowers his next basic attack, then creates a gravity field at the target location. Enemies inside are slowed; enemies still in the field when it collapses are stunned. When evolved, the field also disrupts movement skills.",
        "ult": "R - Arcane Storm: Viktor summons an arcane storm at the target location, dealing an initial burst of magic damage and disrupting enemy skills. The storm then pulses repeatedly. Casting Arcane Storm advances Glorious Evolution; once fully evolved, the storm is larger, lasts longer, and pulses faster."
      },
      "bo_league_champions_veigar": {
        "name": "Veigar",
        "attack": "Fires a magic bolt at a target, dealing <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> as <#ff9028ff>physical damage<>.",
        "skill": "Calls down dark matter at a target location after a short delay, dealing <#a974ffff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>180% AP<> <#a974ffff>magic damage<> within <#ffb900ff>35 range<>. Enemy champion hits grant <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>22 AP until death<>; minions take half damage.",
        "skill2": "Creates an Event Horizon cage. After <#ffb900ff>1.0s<>, enemy champions inside are <#ef5350ff>stunned for 1.5s<> and the cage disappears.",
        "ult": "Fires a burst of dark magic at an enemy champion, dealing <#a974ffff>150<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>200% AP<> <#a974ffff>magic damage<>."
      },
      "bo_league_champions_jhin": {
        "name": "Jhin",
        "attack": "Fires a shot at the target, dealing <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> as <#ff9028ff>physical damage<>. Every fourth attack uses a red projectile and deals <#ff9028ff>100<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>200% attack damage<>. After the fourth shot, Jhin reloads with heavily reduced attack speed until his next attack.",
        "skill": "Dancing Grenade: throws a bouncing grenade at an enemy within range. The grenade can jump to another nearby enemy and deals <#ff9028ff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75% attack damage<> as <#ff9028ff>physical damage<> on hit.",
        "skill2": "Deadly Flourish: fires a long line shot, dealing <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% attack damage<> as <#ff9028ff>physical damage<> to enemy champions and <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>30% attack damage<> to minions. Enemy champions hit are <#ef5350ff>stunned for 0.5s<>.",
        "ult": "Curtain Call: roots Jhin in place and fires four champion-only bullets in the chosen direction. Each bullet stops on the first enemy champion hit. The first three shots deal <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% attack damage<> as <#ff9028ff>physical damage<>; the larger red fourth shot deals <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>300% attack damage<>."
      },
      "bo_league_champions_vayne": {
        "name": "Vayne",
        "attack": "Fires a crossbow bolt at the target, dealing <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> as <#ff9028ff>physical damage<>. Every third basic attack triggers Silver Bolts, dealing <#f5f5f5ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>35% attack damage<> + <#f5f5f5ff>4% target max HP<> as <#f5f5f5ff>fixed damage<>.",
        "skill": "Tumble: rolls a short distance in the chosen direction and empowers the next basic attack to deal <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% attack damage<>. During Final Hour, Tumble travels farther and makes Vayne <#ffb900ff>invisible for 1.5s<>.",
        "skill2": "Silver Bolts: passive, available at level 1 and always active. Every third basic attack deals bonus <#f5f5f5ff>fixed damage<>.",
        "ult": "Final Hour: for <#ffb900ff>10.0s<>, Vayne gains <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>50 attack damage<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% movement speed<>, <i#asset/base/ui/banpick/champion_stat_icon:attack_speed_0><#ceff99ff>20% attack speed<>, and faster skill cooldown recovery. While active, Tumble grants invisibility."
      },
      "bo_league_champions_fiddlesticks": {
        "name": "Fiddlesticks",
        "attack": "Hurls a crow-shaped bolt at the target, dealing <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% AP<> as <#a974ffff>magic damage<>.",
        "skill": "Terrify: sends a nightmare projectile at an enemy champion, dealing <#a974ffff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>70% AP<> <#a974ffff>magic damage<> and fearing them for 1.25 seconds.",
        "skill2": "Bountiful Harvest: briefly drains nearby enemies, repeatedly dealing <#a974ffff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>25% AP<> <#a974ffff>magic damage<> and healing Fiddlesticks for <#6aff55ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#6aff55ff>8% AP<> per enemy hit.",
        "ult": "Crowstorm: blinks to an enemy champion, briefly fears nearby enemy champions, and surrounds Fiddlesticks with a storm for 2 seconds, repeatedly dealing <#a974ffff>26<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>30% AP<> <#a974ffff>magic damage<> to nearby enemies."
      },
      "bo_league_champions_azir": {
        "name": "Azir",
        "attack": "Azir commands sand magic at the target, dealing 75% AP magic damage and occasionally spawning sand soldiers to join the fight.",
        "skill": "Arise!: sends a sand soldier to a target location, dealing 30 + 60% AP magic damage to enemies it passes through. When it arrives, the soldier remains and attacks nearby enemies, dealing 15 + 70% AP magic damage per strike to champions.",
        "skill2": "Shifting Sands: summons a sand soldier and dashes to it, gaining a 70 + 45% AP shield. Enemies Azir passes through take 40 + 45% AP magic damage. The soldier remains after the dash.",
        "ult": "Emperor's Divide: sends a wall of soldiers forward, dealing 120 + 100% AP magic damage to enemies in its path, knocking them back, and briefly knocking them airborne. The wall briefly remains, disrupting movement through it."
      },
      "bo_league_champions_fizz": {
        "name": "Fizz",
        "attack": "Strikes the target in melee, dealing <#a974ffff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>100% AP<> <#a974ffff>magic damage<>. After Urchin Strike, basic attacks briefly apply poison on hit.",
        "skill": "Urchin Strike: dashes through the target and lands behind them, dealing <#a974ffff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>55% AP<> <#a974ffff>magic damage<> and poisoning them for <#ffb900ff>3.0s<>. For <#ffb900ff>4.0s<> after hitting, Fizz basic attacks apply a lighter poison on hit.",
        "skill2": "Playful / Trickster: vaults toward a chosen enemy or ally direction, pausing briefly on the pole while <#ffb900ff>invisible, damage-reduced, and crowd-control immune for 2.4s<>, then makes a short descent movement and splashes down to deal <#a974ffff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>65% AP<> <#a974ffff>magic damage<> and <#ef5350ff>slow nearby enemies for 0.5s<>.",
        "ult": "Chum the Waters: throws a long-range fish in the chosen direction. The fish stops on the first enemy champion hit, <#ef5350ff>heavily slowing them for 2.5s<>; if it misses, it reaches the end of its path. A shark appears during the slow, then erupts to deal <#a974ffff>240<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>140% AP<> <#a974ffff>magic damage<> and <#ef5350ff>knock enemies airborne<>."
      },
      "bo_league_champions_ezreal": {
        "name": "Ezreal",
        "attack": "Fires an energy bolt at the target, dealing <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> as <#ff9028ff>physical damage<>.",
        "skill": "Mystic Shot: fires a fast skillshot in the chosen direction, stopping on the first enemy hit and dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as <#ff9028ff>physical damage<> to champions. Minions take half damage.",
        "skill2": "Arcane Shift: blinks a short distance in the chosen direction.",
        "ult": "Trueshot Barrage: fires an unlimited-range attack toward enemies, dealing <#ff9028ff>220<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as <#ff9028ff>physical damage<>, plus <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>70% AP<> as <#a974ffff>magic damage<> to enemies hit."
      },
      "test_mod_aatrox": {
        "name": "Aatrox",
        "attack": "Deathbringer Stance: empowers the next greatsword strike, dealing <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>112% attack damage<> as <#ff9028ff>physical damage<>.",
        "skill": "Q - The Darkin Blade: each cast releases one strike of Aatrox's three-part blade combo. Q1 is a narrow thrust, Q2 is a wide cleave, and Q3 is a heavy smash that hits hardest and <#ef5350ff>knocks enemies airborne for 0.5s<>. Casting Q again advances to the next strike instead of firing all three at once.",
        "skill2": "W - Infernal Chains: Aatrox fires a demonic chain in a line, damaging and <#ffb900ff>slowing<> enemy champions hit. After a short delay the chain snaps back, dealing damage again and briefly locking enemies caught in the path.",
        "ult": "R - World Ender: Aatrox reveals his demonic form for <#ffb900ff>10.0s<>, gaining <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75 attack damage<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% movement speed<> and <#6aff55ff>50% vamp<>. Nearby enemies are briefly feared on cast."
