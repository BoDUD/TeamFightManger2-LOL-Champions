      "bo_league_champions_yasuo": {
        "name": "Yasuo (Unforgiven)",
        "attack": "Way of the Wanderer: Yasuo slashes with his katana, dealing <#ff9028ff>8<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> physical damage. Every third basic attack grants a short Flow shield.",
        "skill": "Q - Steel Tempest: each cast thrusts a wind blade forward, dealing <#ff9028ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% attack damage<>. The second Q is stronger. The third Q fires a tornado that knocks enemies airborne and readies Last Breath.",
        "skill2": "W/E - Sweeping Blade + Wind Wall: Yasuo dashes through the chosen direction, slicing enemies for <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>55% attack damage<>, gaining a small shield, then raises a wind wall that blocks movement skills and pushes enemies back.",
        "ult": "R - Last Breath: Yasuo blinks behind an enemy champion and strikes for <#ff9028ff>110<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>120% attack damage<>. If Steel Tempest tornado recently hit, Last Breath becomes empowered, dealing higher damage in an area and knocking enemies airborne."
      },
      "test_mod_yasuo": {
        "name": "Yasuo (Unforgiven)",
        "attack": "Way of the Wanderer: Yasuo slashes with his katana, dealing <#ff9028ff>8<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% attack damage<> physical damage. Every third basic attack grants a short Flow shield.",
        "skill": "Q - Steel Tempest: each cast thrusts a wind blade forward, dealing <#ff9028ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% attack damage<>. The second Q is stronger. The third Q fires a tornado that knocks enemies airborne and readies Last Breath.",
        "skill2": "W/E - Sweeping Blade + Wind Wall: Yasuo dashes through the chosen direction, slicing enemies for <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>55% attack damage<>, gaining a small shield, then raises a wind wall that blocks movement skills and pushes enemies back.",
        "ult": "R - Last Breath: Yasuo blinks behind an enemy champion and strikes for <#ff9028ff>110<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>120% attack damage<>. If Steel Tempest tornado recently hit, Last Breath becomes empowered, dealing higher damage in an area and knocking enemies airborne."
      },
      "bo_league_champions_jinx": {
        "name": "Jinx (Loose Cannon)",
        "attack": "Pow-Pow / Fishbones: basic attacks default to Pow-Pow and build minigun attack speed. During the short Fishbones window, attacks become splash rockets and clear Pow-Pow stacks.",
        "skill": "Switcheroo!: when an enemy target is available, Jinx briefly swaps to Fishbones for splash rocket attacks, then automatically returns to Pow-Pow.",
        "skill2": "Zap! + Flame Chompers!: fires a long electric shot that damages and slows, then throws Flame Chompers ahead to bite, stun, and burn enemies caught in the line.",
        "ult": "Super Mega Death Rocket!: fires a huge shark rocket across the map. On champion hit it explodes, deals heavy physical damage, and triggers Get Excited movement and attack speed."
      },
      "test_mod_jinx": {
        "name": "Jinx (Loose Cannon)",
        "attack": "Pow-Pow / Fishbones: basic attacks default to Pow-Pow and build minigun attack speed. During the short Fishbones window, attacks become splash rockets and clear Pow-Pow stacks.",
        "skill": "Switcheroo!: when an enemy target is available, Jinx briefly swaps to Fishbones for splash rocket attacks, then automatically returns to Pow-Pow.",
        "skill2": "Zap! + Flame Chompers!: fires a long electric shot that damages and slows, then throws Flame Chompers ahead to bite, stun, and burn enemies caught in the line.",
        "ult": "Super Mega Death Rocket!: fires a huge shark rocket across the map. On champion hit it explodes, deals heavy physical damage, and triggers Get Excited movement and attack speed."
      },
      "bo_league_champions_thresh": {
        "name": "Thresh (Chain Warden)",
        "attack": "Damnation / Flay chain: Thresh lashes with his chain scythe for <#ff9028ff>physical damage<> and a small <#a974ffff>magic burn<>. Every third basic attack becomes an empowered soul lash that slows the target and resets the chain-charge cycle.",
        "skill": "Q - Death Sentence: Thresh throws a non-piercing hook chain in a long line. The first enemy hit takes <#a974ffff>65<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> magic damage, is stunned, heavily slowed, and has movement skills briefly blocked. Champion hits grant a permanent Damnation soul stack.",
        "skill2": "W/E - Dark Passage / Flay: Thresh lights his lantern to shield himself, then sweeps the chain scythe forward. Enemies hit take magic damage, are pushed back, slowed, and grant a Damnation soul stack on champion hit.",
        "ult": "R - The Box: Thresh summons spectral prison walls around himself. Enemies inside take heavy magic damage, are strongly slowed, and have movement skills briefly blocked. The Box lingers as a slowing field, and champion hits grant permanent souls."
      },
      "test_mod_thresh": {
        "name": "Thresh (Chain Warden)",
        "attack": "Damnation / Flay chain: Thresh lashes with his chain scythe for <#ff9028ff>physical damage<> and a small <#a974ffff>magic burn<>. Every third basic attack becomes an empowered soul lash that slows the target and resets the chain-charge cycle.",
        "skill": "Q - Death Sentence: Thresh throws a non-piercing hook chain in a long line. The first enemy hit takes <#a974ffff>65<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> magic damage, is stunned, heavily slowed, and has movement skills briefly blocked. Champion hits grant a permanent Damnation soul stack.",
        "skill2": "W/E - Dark Passage / Flay: Thresh lights his lantern to shield himself, then sweeps the chain scythe forward. Enemies hit take magic damage, are pushed back, slowed, and grant a Damnation soul stack on champion hit.",
        "ult": "R - The Box: Thresh summons spectral prison walls around himself. Enemies inside take heavy magic damage, are strongly slowed, and have movement skills briefly blocked. The Box lingers as a slowing field, and champion hits grant permanent souls."
      },
      "bo_league_champions_darius": {
        "name": "Darius",
        "attack": "Hemorrhage: Darius, the Hand of Noxus, cleaves with his axe for <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as physical damage and advances Hemorrhage. At five stacks he gains Noxian Might. If Crippling Strike is primed, the next attack deals heavier damage and <#ef5350ff>slows<> the target.",
        "skill": "Q - Decimate: Darius spins his axe in a red outer circle, dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> as physical damage, applying Hemorrhage, and healing himself when enemies are struck. During Noxian Might, Decimate deals more damage and heals more.",
        "skill2": "E/W - Apprehend and Crippling Strike: Darius sweeps his axe forward in a chain-like hook line, dealing <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>60% attack damage<>, briefly stunning, slowing, and blocking movement skills. The cast primes his next attack as Crippling Strike.",
        "ult": "R - Noxian Guillotine: Darius rushes behind an enemy champion and executes with true damage. The blow scales with Hemorrhage stacks, reaches its highest damage at five stacks or during Noxian Might, and plays Darius's Noxian Guillotine voice line."
      },
      "test_mod_darius": {
        "name": "Darius",
        "attack": "Hemorrhage: Darius, the Hand of Noxus, cleaves with his axe for <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% attack damage<> as physical damage and advances Hemorrhage. At five stacks he gains Noxian Might. If Crippling Strike is primed, the next attack deals heavier damage and <#ef5350ff>slows<> the target.",
        "skill": "Q - Decimate: Darius spins his axe in a red outer circle, dealing <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>95% attack damage<> as physical damage, applying Hemorrhage, and healing himself when enemies are struck. During Noxian Might, Decimate deals more damage and heals more.",
        "skill2": "E/W - Apprehend and Crippling Strike: Darius sweeps his axe forward in a chain-like hook line, dealing <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>60% attack damage<>, briefly stunning, slowing, and blocking movement skills. The cast primes his next attack as Crippling Strike.",
        "ult": "R - Noxian Guillotine: Darius rushes behind an enemy champion and executes with true damage. The blow scales with Hemorrhage stacks, reaches its highest damage at five stacks or during Noxian Might, and plays Darius's Noxian Guillotine voice line."
      }
    }
  },
  "vi": {
    "description": {
      "bo_league_champions_aatrox": {
        "name": "Aatrox",
        "attack": "Deathbringer Stance: empowers the next greatsword strike, dealing <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>112% attack damage<> as <#ff9028ff>physical damage<>.",
        "skill": "Q - The Darkin Blade: each cast releases one strike of Aatrox's three-part blade combo. Q1 is a narrow thrust, Q2 is a wide cleave, and Q3 is a heavy smash that hits hardest and <#ef5350ff>knocks enemies airborne for 0.5s<>. Casting Q again advances to the next strike instead of firing all three at once.",
        "skill2": "W - Infernal Chains: Aatrox fires a demonic chain in a line, damaging and <#ffb900ff>slowing<> enemy champions hit. After a short delay the chain snaps back, dealing damage again and briefly locking enemies caught in the path.",
        "ult": "R - World Ender: Aatrox reveals his demonic form for <#ffb900ff>10.0s<>, gaining <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75 attack damage<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% movement speed<> and <#6aff55ff>50% vamp<>. Nearby enemies are briefly feared on cast."
      },
      "bo_league_champions_viktor": {
        "name": "Viktor",
        "attack": "Arcane Pulse: Viktor fires an arcane bolt, dealing <#a974ffff>12<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> as magic damage. While Siphon Empower is active, his next basic attack deals <#a974ffff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>115% magic power<> and grants Viktor a shield.",
        "skill": "E - Hextech Ray: Viktor's third arm fires a laser in the target direction, dealing magic damage to enemies in a line. When evolved, the ray leaves an aftershock that detonates shortly after, damaging and briefly slowing enemies. Hitting an enemy champion advances Glorious Evolution.",
        "skill2": "Q/W - Siphon Power + Gravity Field: Viktor shields himself and empowers his next basic attack, then creates a gravity field at the target location. Enemies inside are slowed; enemies still in the field when it collapses are stunned. When evolved, the field also disrupts movement skills.",
        "ult": "R - Arcane Storm: Viktor summons an arcane storm at the target location, dealing an initial burst of magic damage and disrupting enemy skills. The storm then pulses repeatedly. Casting Arcane Storm advances Glorious Evolution; once fully evolved, the storm is larger, lasts longer, and pulses faster."
      },
      "bo_league_champions_veigar": {
        "name": "Veigar",
        "attack": "Bắn một tia ma thuật vào mục tiêu, gây <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>.",
        "skill": "Gọi Vật Chất Tối xuống vị trí chỉ định sau một thoáng trễ, gây <#a974ffff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>180% AP<> <#a974ffff>sát thương phép<> trong <#ffb900ff>phạm vi 35<>. Trúng tướng địch cho <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>22 AP cho đến khi chết<>; lính chịu nửa sát thương.",
        "skill2": "Tạo một lồng Bẻ Cong Không Gian. Sau <#ffb900ff>1.0 giây<>, tướng địch bên trong bị <#ef5350ff>choáng trong 1.5 giây<> rồi lồng biến mất.",
        "ult": "Bắn một luồng ma thuật hắc ám vào tướng địch, gây <#a974ffff>150<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>200% AP<> <#a974ffff>sát thương phép<>."
      },
      "bo_league_champions_jhin": {
        "name": "Jhin",
        "attack": "Bắn mục tiêu, gây <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>. Mỗi đòn đánh thứ tư dùng đạn đỏ và gây <#ff9028ff>100<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>200% sức mạnh công kích<>. Sau phát bắn thứ tư, Jhin nạp đạn với tốc độ đánh giảm mạnh cho đến đòn đánh kế tiếp.",
        "skill": "Lựu Đạn Nhảy Múa: ném một quả lựu đạn nảy vào kẻ địch trong tầm. Lựu đạn có thể nảy sang một kẻ địch gần đó và gây <#ff9028ff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<> khi trúng.",
        "skill2": "Nét Vẽ Chết Chóc: bắn một phát đạn dài theo đường thẳng, gây <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<> lên tướng địch và <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>30% sức mạnh công kích<> lên lính. Tướng địch trúng chiêu bị <#ef5350ff>choáng trong 0.5 giây<>.",
        "ult": "Sân Khấu Tử Thần: trói chân Jhin tại chỗ và bắn bốn viên đạn chỉ trúng tướng theo hướng đã chọn. Mỗi viên dừng lại khi trúng tướng địch đầu tiên. Ba phát đầu gây <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>; phát đỏ thứ tư lớn hơn gây <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>300% sức mạnh công kích<>."
      },
      "bo_league_champions_vayne": {
        "name": "Vayne",
        "attack": "Bắn một mũi tên nỏ vào mục tiêu, gây <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>. Mỗi đòn đánh thường thứ ba kích hoạt Mũi Tên Bạc, gây <#f5f5f5ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>35% sức mạnh công kích<> + <#f5f5f5ff>4% máu tối đa của mục tiêu<> thành <#f5f5f5ff>sát thương chuẩn<>.",
        "skill": "Nhào Lộn: lăn một đoạn ngắn theo hướng đã chọn và cường hóa đòn đánh thường kế tiếp để gây <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% sức mạnh công kích<>. Trong Giờ Khắc Cuối Cùng, Nhào Lộn đi xa hơn và khiến Vayne <#ffb900ff>tàng hình trong 1.5 giây<>.",
        "skill2": "Mũi Tên Bạc: nội tại, có từ cấp 1 và luôn hoạt động. Mỗi đòn đánh thường thứ ba gây thêm <#f5f5f5ff>sát thương chuẩn<>.",
        "ult": "Giờ Khắc Cuối Cùng: trong <#ffb900ff>10.0 giây<>, Vayne nhận <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>50 sức mạnh công kích<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% tốc độ di chuyển<>, <i#asset/base/ui/banpick/champion_stat_icon:attack_speed_0><#ceff99ff>20% tốc độ đánh<> và hồi chiêu kỹ năng nhanh hơn. Khi còn hiệu lực, Nhào Lộn cho tàng hình."
      },
      "bo_league_champions_fiddlesticks": {
        "name": "Fiddlesticks",
        "attack": "Ném một tia hình quạ vào mục tiêu, gây <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% AP<> thành <#a974ffff>sát thương phép<>.",
        "skill": "Kinh Hãi: phóng một ác mộng vào tướng địch, gây <#a974ffff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>70% AP<> <#a974ffff>sát thương phép<> và khiến chúng hoảng sợ trong 1.25 giây.",
        "skill2": "Gặt Hái Dồi Dào: hút cạn kẻ địch gần đó trong thời gian ngắn, liên tục gây <#a974ffff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>25% AP<> <#a974ffff>sát thương phép<> và hồi cho Fiddlesticks <#6aff55ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#6aff55ff>8% AP<> với mỗi kẻ địch trúng.",
        "ult": "Bão Quạ: dịch chuyển tới một tướng địch, khiến tướng địch gần đó hoảng sợ trong thời gian ngắn, rồi bao quanh Fiddlesticks bằng cơn bão trong 2 giây, liên tục gây <#a974ffff>26<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>30% AP<> <#a974ffff>sát thương phép<> lên kẻ địch gần đó."
      },
      "bo_league_champions_azir": {
        "name": "Azir",
        "attack": "Azir điều khiển cát ma thuật tấn công mục tiêu, gây 75% AP sát thương phép và đôi khi triệu hồi lính cát tham chiến.",
        "skill": "Trỗi Dậy!: đưa một lính cát tới vị trí mục tiêu, gây 30 + 60% AP sát thương phép lên kẻ địch nó đi xuyên qua. Khi tới nơi, lính cát ở lại và tấn công kẻ địch gần đó, gây 15 + 70% AP sát thương phép mỗi đòn lên tướng.",
        "skill2": "Cát Lưu Động: triệu hồi một lính cát rồi lao tới nó, nhận lá chắn 70 + 45% AP. Kẻ địch Azir đi xuyên qua chịu 40 + 45% AP sát thương phép. Lính cát ở lại sau cú lao.",
        "ult": "Phân Chia Hoàng Đế: đưa một bức tường lính cát tiến về phía trước, gây 120 + 100% AP sát thương phép lên kẻ địch trên đường đi, đẩy lùi và hất tung chúng trong thời gian ngắn. Bức tường tồn tại thêm một lúc, cản trở di chuyển xuyên qua nó."
      },
      "bo_league_champions_fizz": {
        "name": "Fizz",
        "attack": "Đánh cận chiến mục tiêu, gây <#a974ffff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>100% AP<> <#a974ffff>sát thương phép<>. Sau Đâm Lao, đòn đánh thường sẽ tạm thời gây độc khi trúng.",
        "skill": "Đâm Lao: lao xuyên qua mục tiêu và đáp xuống phía sau, gây <#a974ffff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>55% AP<> <#a974ffff>sát thương phép<> và đầu độc chúng trong <#ffb900ff>3.0 giây<>. Trong <#ffb900ff>4.0 giây<> sau khi trúng, đòn đánh thường của Fizz gây một độc nhẹ hơn khi trúng.",
        "skill2": "Tung Tăng / Nhảy Múa: phóng về hướng kẻ địch hoặc đồng minh đã chọn, tạm dừng trên cây đinh ba trong khi <#ffb900ff>tàng hình, giảm sát thương nhận vào và miễn nhiễm khống chế trong 2.4 giây<>, rồi rơi xuống một đoạn ngắn và văng nước, gây <#a974ffff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>65% AP<> <#a974ffff>sát thương phép<> và <#ef5350ff>làm chậm kẻ địch gần đó trong 0.5 giây<>.",
        "ult": "Triệu Hồi Thủy Quái: ném một con cá tầm xa theo hướng đã chọn. Cá dừng lại khi trúng tướng địch đầu tiên, <#ef5350ff>làm chậm mạnh chúng trong 2.5 giây<>; nếu trượt, nó đi tới cuối đường bay. Một con cá mập xuất hiện trong lúc làm chậm, rồi trồi lên gây <#a974ffff>240<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>140% AP<> <#a974ffff>sát thương phép<> và <#ef5350ff>hất tung kẻ địch<>."
      },
      "bo_league_champions_ezreal": {
        "name": "Ezreal",
        "attack": "Bắn một tia năng lượng vào mục tiêu, gây <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>.",
        "skill": "Phát Bắn Thần Bí: bắn một phát kỹ năng nhanh theo hướng đã chọn, dừng lại khi trúng kẻ địch đầu tiên và gây <#ff9028ff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<> lên tướng. Lính chịu một nửa sát thương.",
        "skill2": "Dịch Chuyển Cổ Học: dịch chuyển một đoạn ngắn theo hướng đã chọn.",
        "ult": "Cung Ánh Sáng Tối Thượng: bắn một đòn tấn công không giới hạn tầm về phía kẻ địch, gây <#ff9028ff>220<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>110% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>, cộng thêm <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>70% AP<> thành <#a974ffff>sát thương phép<> lên kẻ địch trúng đòn."
      },
      "test_mod_aatrox": {
        "name": "Aatrox",
        "attack": "Deathbringer Stance: empowers the next greatsword strike, dealing <#ff9028ff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>112% attack damage<> as <#ff9028ff>physical damage<>.",
        "skill": "Q - The Darkin Blade: each cast releases one strike of Aatrox's three-part blade combo. Q1 is a narrow thrust, Q2 is a wide cleave, and Q3 is a heavy smash that hits hardest and <#ef5350ff>knocks enemies airborne for 0.5s<>. Casting Q again advances to the next strike instead of firing all three at once.",
        "skill2": "W - Infernal Chains: Aatrox fires a demonic chain in a line, damaging and <#ffb900ff>slowing<> enemy champions hit. After a short delay the chain snaps back, dealing damage again and briefly locking enemies caught in the path.",
        "ult": "R - World Ender: Aatrox reveals his demonic form for <#ffb900ff>10.0s<>, gaining <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75 attack damage<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% movement speed<> and <#6aff55ff>50% vamp<>. Nearby enemies are briefly feared on cast."
      },
      "test_mod_viktor": {
        "name": "Viktor",
        "attack": "Arcane Pulse: Viktor fires an arcane bolt, dealing <#a974ffff>12<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% magic power<> as magic damage. While Siphon Empower is active, his next basic attack deals <#a974ffff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>115% magic power<> and grants Viktor a shield.",
        "skill": "E - Hextech Ray: Viktor's third arm fires a laser in the target direction, dealing magic damage to enemies in a line. When evolved, the ray leaves an aftershock that detonates shortly after, damaging and briefly slowing enemies. Hitting an enemy champion advances Glorious Evolution.",
        "skill2": "Q/W - Siphon Power + Gravity Field: Viktor shields himself and empowers his next basic attack, then creates a gravity field at the target location. Enemies inside are slowed; enemies still in the field when it collapses are stunned. When evolved, the field also disrupts movement skills.",
        "ult": "R - Arcane Storm: Viktor summons an arcane storm at the target location, dealing an initial burst of magic damage and disrupting enemy skills. The storm then pulses repeatedly. Casting Arcane Storm advances Glorious Evolution; once fully evolved, the storm is larger, lasts longer, and pulses faster."
      },
      "test_mod_veigar": {
        "name": "Veigar",
        "attack": "Bắn một tia ma thuật vào mục tiêu, gây <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>.",
        "skill": "Gọi Vật Chất Tối xuống vị trí chỉ định sau một thoáng trễ, gây <#a974ffff>50<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>180% AP<> <#a974ffff>sát thương phép<> trong <#ffb900ff>phạm vi 35<>. Trúng tướng địch cho <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>22 AP cho đến khi chết<>; lính chịu nửa sát thương.",
        "skill2": "Tạo một lồng Bẻ Cong Không Gian. Sau <#ffb900ff>1.0 giây<>, tướng địch bên trong bị <#ef5350ff>choáng trong 1.5 giây<> rồi lồng biến mất.",
        "ult": "Bắn một luồng ma thuật hắc ám vào tướng địch, gây <#a974ffff>150<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>200% AP<> <#a974ffff>sát thương phép<>."
      },
      "test_mod_jhin": {
        "name": "Jhin",
        "attack": "Bắn mục tiêu, gây <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>. Mỗi đòn đánh thứ tư dùng đạn đỏ và gây <#ff9028ff>100<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>200% sức mạnh công kích<>. Sau phát bắn thứ tư, Jhin nạp đạn với tốc độ đánh giảm mạnh cho đến đòn đánh kế tiếp.",
        "skill": "Lựu Đạn Nhảy Múa: ném một quả lựu đạn nảy vào kẻ địch trong tầm. Lựu đạn có thể nảy sang một kẻ địch gần đó và gây <#ff9028ff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>75% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<> khi trúng.",
        "skill2": "Nét Vẽ Chết Chóc: bắn một phát đạn dài theo đường thẳng, gây <#ff9028ff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>70% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<> lên tướng địch và <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>30% sức mạnh công kích<> lên lính. Tướng địch trúng chiêu bị <#ef5350ff>choáng trong 0.5 giây<>.",
        "ult": "Sân Khấu Tử Thần: trói chân Jhin tại chỗ và bắn bốn viên đạn chỉ trúng tướng theo hướng đã chọn. Mỗi viên dừng lại khi trúng tướng địch đầu tiên. Ba phát đầu gây <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>; phát đỏ thứ tư lớn hơn gây <#ff9028ff>300<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>300% sức mạnh công kích<>."
      },
      "test_mod_vayne": {
        "name": "Vayne",
        "attack": "Bắn một mũi tên nỏ vào mục tiêu, gây <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>100% sức mạnh công kích<> thành <#ff9028ff>sát thương vật lý<>. Mỗi đòn đánh thường thứ ba kích hoạt Mũi Tên Bạc, gây <#f5f5f5ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>35% sức mạnh công kích<> + <#f5f5f5ff>4% máu tối đa của mục tiêu<> thành <#f5f5f5ff>sát thương chuẩn<>.",
        "skill": "Nhào Lộn: lăn một đoạn ngắn theo hướng đã chọn và cường hóa đòn đánh thường kế tiếp để gây <#ff9028ff>35<> + <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>150% sức mạnh công kích<>. Trong Giờ Khắc Cuối Cùng, Nhào Lộn đi xa hơn và khiến Vayne <#ffb900ff>tàng hình trong 1.5 giây<>.",
        "skill2": "Mũi Tên Bạc: nội tại, có từ cấp 1 và luôn hoạt động. Mỗi đòn đánh thường thứ ba gây thêm <#f5f5f5ff>sát thương chuẩn<>.",
        "ult": "Giờ Khắc Cuối Cùng: trong <#ffb900ff>10.0 giây<>, Vayne nhận <i#asset/base/ui/banpick/champion_stat_icon:ad_0><#ff9028ff>50 sức mạnh công kích<>, <i#asset/base/ui/banpick/champion_stat_icon:speed_0><#ffffffff>20% tốc độ di chuyển<>, <i#asset/base/ui/banpick/champion_stat_icon:attack_speed_0><#ceff99ff>20% tốc độ đánh<> và hồi chiêu kỹ năng nhanh hơn. Khi còn hiệu lực, Nhào Lộn cho tàng hình."
      },
      "test_mod_fiddlesticks": {
        "name": "Fiddlesticks",
        "attack": "Ném một tia hình quạ vào mục tiêu, gây <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>75% AP<> thành <#a974ffff>sát thương phép<>.",
        "skill": "Kinh Hãi: phóng một ác mộng vào tướng địch, gây <#a974ffff>45<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>70% AP<> <#a974ffff>sát thương phép<> và khiến chúng hoảng sợ trong 1.25 giây.",
        "skill2": "Gặt Hái Dồi Dào: hút cạn kẻ địch gần đó trong thời gian ngắn, liên tục gây <#a974ffff>18<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>25% AP<> <#a974ffff>sát thương phép<> và hồi cho Fiddlesticks <#6aff55ff>30<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#6aff55ff>8% AP<> với mỗi kẻ địch trúng.",
        "ult": "Bão Quạ: dịch chuyển tới một tướng địch, khiến tướng địch gần đó hoảng sợ trong thời gian ngắn, rồi bao quanh Fiddlesticks bằng cơn bão trong 2 giây, liên tục gây <#a974ffff>26<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>30% AP<> <#a974ffff>sát thương phép<> lên kẻ địch gần đó."
      },
      "test_mod_azir": {
        "name": "Azir",
        "attack": "Azir điều khiển cát ma thuật tấn công mục tiêu, gây 75% AP sát thương phép và đôi khi triệu hồi lính cát tham chiến.",
        "skill": "Trỗi Dậy!: đưa một lính cát tới vị trí mục tiêu, gây 30 + 60% AP sát thương phép lên kẻ địch nó đi xuyên qua. Khi tới nơi, lính cát ở lại và tấn công kẻ địch gần đó, gây 15 + 70% AP sát thương phép mỗi đòn lên tướng.",
        "skill2": "Cát Lưu Động: triệu hồi một lính cát rồi lao tới nó, nhận lá chắn 70 + 45% AP. Kẻ địch Azir đi xuyên qua chịu 40 + 45% AP sát thương phép. Lính cát ở lại sau cú lao.",
        "ult": "Phân Chia Hoàng Đế: đưa một bức tường lính cát tiến về phía trước, gây 120 + 100% AP sát thương phép lên kẻ địch trên đường đi, đẩy lùi và hất tung chúng trong thời gian ngắn. Bức tường tồn tại thêm một lúc, cản trở di chuyển xuyên qua nó."
      },
      "test_mod_fizz": {
        "name": "Fizz",
        "attack": "Đánh cận chiến mục tiêu, gây <#a974ffff>10<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>100% AP<> <#a974ffff>sát thương phép<>. Sau Đâm Lao, đòn đánh thường sẽ tạm thời gây độc khi trúng.",
        "skill": "Đâm Lao: lao xuyên qua mục tiêu và đáp xuống phía sau, gây <#a974ffff>40<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>55% AP<> <#a974ffff>sát thương phép<> và đầu độc chúng trong <#ffb900ff>3.0 giây<>. Trong <#ffb900ff>4.0 giây<> sau khi trúng, đòn đánh thường của Fizz gây một độc nhẹ hơn khi trúng.",
        "skill2": "Tung Tăng / Nhảy Múa: phóng về hướng kẻ địch hoặc đồng minh đã chọn, tạm dừng trên cây đinh ba trong khi <#ffb900ff>tàng hình, giảm sát thương nhận vào và miễn nhiễm khống chế trong 2.4 giây<>, rồi rơi xuống một đoạn ngắn và văng nước, gây <#a974ffff>70<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>65% AP<> <#a974ffff>sát thương phép<> và <#ef5350ff>làm chậm kẻ địch gần đó trong 0.5 giây<>.",
        "ult": "Triệu Hồi Thủy Quái: ném một con cá tầm xa theo hướng đã chọn. Cá dừng lại khi trúng tướng địch đầu tiên, <#ef5350ff>làm chậm mạnh chúng trong 2.5 giây<>; nếu trượt, nó đi tới cuối đường bay. Một con cá mập xuất hiện trong lúc làm chậm, rồi trồi lên gây <#a974ffff>240<> + <i#asset/base/ui/banpick/champion_stat_icon:ap_0><#a974ffff>140% AP<> <#a974ffff>sát thương phép<> và <#ef5350ff>hất tung kẻ địch<>."
      },
      "test_mod_ezreal": {
